BGG_API_TOKEN=...

# --- LiteLLM proxy ---
LITELLM_BASE_URL=...
LITELLM_API_KEY=...

# --- Model configuration ---
# Reasoning model (beefy, used for query expansion + image reasoning)
# Must support vision for image queries
SPIELBOT_REASON_MODEL=gpt-5

# Generator model (lightweight, used for final answer / grounding)
SPIELBOT_GEN_MODEL=gemini-2.5-flash

# Legacy vision model (only used if calling vision.py standalone)
SPIELBOT_VLM_MODEL=gemini-2.5-flash
