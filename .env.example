BGG_API_TOKEN=...

# --- LiteLLM proxy ---
LITELLM_BASE_URL=...
LITELLM_API_KEY=...

# --- Model configuration ---
# Reasoning model (query expansion + scene description for image queries).
# Must support vision for image queries. Default matches src/reason.py.
# Alternatives: gemini-2.5-pro
SPIELBOT_REASON_MODEL=claude-sonnet-4-20250514-v1:0

# Generator model (lightweight, used for final answer / grounding)
SPIELBOT_GEN_MODEL=gemini-2.5-flash

# Legacy vision model (only used if calling vision.py standalone)
SPIELBOT_VLM_MODEL=gemini-2.5-flash
