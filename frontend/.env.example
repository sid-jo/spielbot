# SpielBot FastAPI — dev uses same-origin proxy (see frontend/vite.config.ts).
# Requests go to /api/... and Vite forwards to http://127.0.0.1:8000 (no CORS issues).
# After changing this file, restart: npm run dev
VITE_API_BASE_URL=/api

# Alternative: call the API directly (requires SPIELBOT_CORS_ORIGINS to include your dev origin):
# VITE_API_BASE_URL=http://127.0.0.1:8000
